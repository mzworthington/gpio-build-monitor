# Copy to /etc/gpio-build-monitor/env on the Raspberry Pi.
GITHUB_TOKEN=replace-me
CIRCLE_CI_TOKEN=replace-me
MONITOR_LOG_DIR=/var/log/gpio-build-monitor

# Auto-update settings (used by bin/update and the systemd timer)
MONITOR_HOME=/home/pi/gpio-build-monitor
MONITOR_VENV=/home/pi/gpio-build-monitor/.venv
MONITOR_SERVICE=gpio-build-monitor
GITHUB_REPO=worthington10TW/gpio-build-monitor
MONITOR_UPDATE_LOG=/var/log/gpio-build-monitor/update.log
